# Aster environment configuration
#
# Copy this file before starting the stack:
#   cp .env.example .env
#
# Values below are examples. Never commit the resulting .env file.

# =============================================================================
# REQUIRED FOR EVERY DEPLOYMENT
# =============================================================================

# Encrypts provider, MCP, communication, and integration credentials.
# Use at least 32 characters. Generate a value with: openssl rand -hex 32
# Keep this value stable. Changing it later makes stored credentials unreadable.
ASTER_ENCRYPTION_KEY=replace-with-a-random-value-containing-at-least-32-characters

# =============================================================================
# DATABASE — CHOOSE ONE MODE
# =============================================================================

# Bundled PostgreSQL (default)
# Keep the local-db profile enabled and leave DATABASE_URL empty.
COMPOSE_PROFILES=local-db
POSTGRES_DB=aster
POSTGRES_USER=aster
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=

# External PostgreSQL
# Disable the bundled profile and provide an async SQLAlchemy URL instead:
# COMPOSE_PROFILES=
# DATABASE_URL=postgresql+asyncpg://user:password@database-host:5432/aster

# =============================================================================
# OPTIONAL SETTINGS
# Remove optional entries to use the application defaults shown below.
# =============================================================================

# -----------------------------------------------------------------------------
# Application and networking
# -----------------------------------------------------------------------------

# Use production for public deployments. Production disables development API docs.
APP_ENVIRONMENT=development

# Host ports published by Docker Compose.
WEB_PORT=3000
API_PORT=8000

# Comma-separated browser origins allowed to call the API.
# Use the public HTTPS web origin in production.
ASTER_CORS_ORIGINS=http://localhost:3000

# Internal API origin used by the Next.js web container.
ASTER_API_INTERNAL_URL=http://api:8000

# -----------------------------------------------------------------------------
# Model and endpoint requests
# -----------------------------------------------------------------------------

# Timeout for non-streaming model and endpoint requests.
ASTER_ENDPOINT_TIMEOUT_SECONDS=30

# Timeout for streamed chat responses.
ASTER_STREAM_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Sessions and login protection
# -----------------------------------------------------------------------------

# Owner session cookie name.
ASTER_SESSION_COOKIE_NAME=aster_session

# Set true when the web application is served exclusively over HTTPS.
ASTER_SESSION_SECURE=false

# Absolute and idle session lifetimes.
ASTER_SESSION_ABSOLUTE_DAYS=30
ASTER_SESSION_IDLE_HOURS=168

# Minimum interval between session activity timestamp updates.
ASTER_SESSION_TOUCH_SECONDS=300

# Login rate limit: attempts allowed inside the configured window.
ASTER_LOGIN_ATTEMPTS=5
ASTER_LOGIN_WINDOW_SECONDS=300

# -----------------------------------------------------------------------------
# MCP and interactive tools
# -----------------------------------------------------------------------------

# Allows configured MCP stdio processes inside the API container.
ASTER_MCP_STDIO_ENABLED=false

# MCP connection and execution timeout.
ASTER_MCP_TIMEOUT_SECONDS=30

# Maximum model/tool rounds in one interactive turn.
ASTER_TOOL_MAX_ROUNDS=8

# Maximum serialized tool arguments and stored tool results.
ASTER_TOOL_ARGUMENT_MAX_CHARACTERS=100000
ASTER_TOOL_RESULT_MAX_CHARACTERS=100000

# -----------------------------------------------------------------------------
# Memory, documents, and retrieval
# -----------------------------------------------------------------------------

# Maximum approved memories and generated memory suggestions per request.
ASTER_MEMORY_MAX_ITEMS=12
ASTER_MEMORY_SUGGESTION_MAX_ITEMS=8

# Retrieval source, context, and candidate limits.
ASTER_RAG_MAX_SOURCES=8
ASTER_RAG_CONTEXT_MAX_CHARACTERS=24000
ASTER_RAG_CANDIDATE_LIMIT=2000

# Document upload and extracted-text limits.
ASTER_DOCUMENT_MAX_BYTES=5000000
ASTER_DOCUMENT_MAX_CHARACTERS=2000000

# Deterministic chunk size, overlap, and per-document chunk ceiling.
# Overlap must remain smaller than the chunk size.
ASTER_DOCUMENT_CHUNK_CHARACTERS=1600
ASTER_DOCUMENT_CHUNK_OVERLAP=200
ASTER_DOCUMENT_MAX_CHUNKS=2000

# Maximum number of inputs sent in one embedding request.
ASTER_EMBEDDING_BATCH_SIZE=64

# -----------------------------------------------------------------------------
# Private media and image operations
# -----------------------------------------------------------------------------

# Shared private-media path mounted by the API and worker containers.
ASTER_MEDIA_ROOT=/var/lib/aster/media

# Provider image-operation timeout.
ASTER_IMAGE_TIMEOUT_SECONDS=300

# Maximum input and provider-output file sizes.
ASTER_IMAGE_UPLOAD_MAX_BYTES=20000000
ASTER_IMAGE_OUTPUT_MAX_BYTES=25000000

# Maximum decoded pixels, edit inputs, and generated outputs.
ASTER_IMAGE_MAX_PIXELS=40000000
ASTER_IMAGE_MAX_INPUTS=8
ASTER_IMAGE_MAX_OUTPUTS=4

# -----------------------------------------------------------------------------
# Automations and integrations
# -----------------------------------------------------------------------------

# Worker polling interval for due automation work.
ASTER_AUTOMATION_POLL_SECONDS=2

# Automation lease and heartbeat durations.
# Heartbeat must remain less than half of the lease duration.
ASTER_AUTOMATION_LEASE_SECONDS=120
ASTER_AUTOMATION_HEARTBEAT_SECONDS=30

# Maximum automation definitions scheduled per worker cycle.
ASTER_AUTOMATION_SCHEDULER_BATCH_SIZE=25

# Maximum stored automation model output.
ASTER_AUTOMATION_OUTPUT_MAX_CHARACTERS=100000

# Timeout shared by SMTP, CalDAV, webhooks, IMAP, and Discord requests.
ASTER_INTEGRATION_TIMEOUT_SECONDS=30

# Maximum inbound webhook body size.
ASTER_WEBHOOK_MAX_BYTES=1000000

# -----------------------------------------------------------------------------
# Communications
# -----------------------------------------------------------------------------

# Synchronization lease duration for communication accounts.
ASTER_COMMUNICATION_LEASE_SECONDS=180

# Maximum persisted message content and individual attachment size.
ASTER_COMMUNICATION_MESSAGE_MAX_CHARACTERS=200000
ASTER_COMMUNICATION_ATTACHMENT_MAX_BYTES=15000000

# Maximum attachments accepted from one inbound message.
ASTER_COMMUNICATION_MAX_ATTACHMENTS=16

# -----------------------------------------------------------------------------
# Autonomous agents
# -----------------------------------------------------------------------------

# Agent run lease and heartbeat durations.
# Heartbeat must remain less than half of the lease duration.
ASTER_AGENT_LEASE_SECONDS=180
ASTER_AGENT_HEARTBEAT_SECONDS=45

# Maximum scheduled agents and communication events processed per cycle.
ASTER_AGENT_SCHEDULER_BATCH_SIZE=25
ASTER_AGENT_DISPATCH_BATCH_SIZE=100

# Maximum final output, serialized history, and retrieval context sizes.
ASTER_AGENT_OUTPUT_MAX_CHARACTERS=100000
ASTER_AGENT_HISTORY_MAX_CHARACTERS=50000
ASTER_AGENT_RETRIEVAL_MAX_CHARACTERS=24000

# Repeated-decision threshold used by agent loop protection.
ASTER_AGENT_LOOP_REPEAT_LIMIT=3
